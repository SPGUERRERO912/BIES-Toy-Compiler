$FUN $0 args : 0 parent : $0
LDF $1
APP 0 ; Ejecutamos splash con 0 argumentos
LDV "Hello World!" ; cargar string "Hello World!"
PRN ; print valor cargado
HLT ; finalización del programa
$END $0
$FUN $1 args : 0 parent : $0
LDV "Testing helloworld Version 1 ***" ; cargar string "Testing helloworld Version 1 ***"
PRN ; print valor cargado
RET ; Fin de la función
$END $1