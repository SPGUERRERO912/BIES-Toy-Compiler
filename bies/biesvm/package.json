{
  "name": "biesvm",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint": "eslint \"src/**/*.mjs\"",
    "format": "prettier --write \"src/**/*.mjs\"",
    "docs": "jsdoc -c jsdoc.json",
    "build": "npm install commander && npm install && npm run prepare",
    "antlr": "cd grammar && java -jar \"../lib/antlr-4.13.1-complete.jar\" -Dlanguage=JavaScript biesvm.g4 -visitor",
    "prepare": "npm run lint && npm run format && npm run antlr && npm run docs && npm run test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "globals": "^15.12.0",
    "jest": "^29.7.0",
    "jsdoc": "^4.0.4",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "antlr4": "^4.13.2",
    "commander": "^12.1.0"
  }
}
